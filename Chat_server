#include <WebServer.h>
#include <WebSocketsServer.h>

const char* ssid = "ESP32-Chat";
const char* password = "12345678";

WebServer server(80);
WebSocketsServer webSocket(81);

String page = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>ESP32 Chat Clean</title>
<style>
body { font-family: Arial; max-width: 700px; margin: auto; padding: 20px; }
.chatbox { border: 1px solid gray; height: 300px; overflow-y: auto; padding: 10px; margin-bottom: 10px; }
input, button { font-size: 16px; padding: 8px; }
.messagebox { width: 70%; }
.status { color: gray; font-style: italic; }
</style>
</head>
<body>

<h2>ESP32 Local Chat Clean Version</h2>

<div class="chatbox" id="chatbox"></div>

<input id="username" placeholder="Name" value="Student">
<br><br>
<input id="message" class="messagebox" placeholder="Message">
<button id="sendbutton">Send</button>

<script>
var chatbox = document.getElementById("chatbox");
var username = document.getElementById("username");
var message = document.getElementById("message");
var sendbutton = document.getElementById("sendbutton");

function writeLine(text) {
  var div = document.createElement("div");
  div.innerHTML = text;
  chatbox.appendChild(div);
  chatbox.scrollTop = chatbox.scrollHeight;
}

var socket = new WebSocket("ws://" + window.location.hostname + ":81/");

socket.onopen = function() {
  writeLine("<span class='status'>Connected</span>");
};

socket.onmessage = function(event) {
  writeLine(event.data);
};

socket.onerror = function() {
  writeLine("<span class='status'>WebSocket error</span>");
};

socket.onclose = function() {
  writeLine("<span class='status'>WebSocket closed</span>");
};

function sendMessage() {
  var text = message.value;

  if (text.trim() == "") {
    return;
  }

  if (socket.readyState != WebSocket.OPEN) {
    writeLine("<span class='status'>Not connected</span>");
    return;
  }

  socket.send("<b>" + username.value + ":</b> " + text);
  message.value = "";
}

sendbutton.addEventListener("click", sendMessage);

message.addEventListener("keydown", function(event) {
  if (event.key == "Enter") {
    sendMessage();
  }
});
</script>

</body>
</html>
)rawliteral";

void handleRoot() {
  server.sendHeader("Cache-Control", "no-store");
  server.send(200, "text/html", page);
}

void webSocketEvent(uint8_t clientNum, WStype_t type, uint8_t * payload, size_t length) {
  if (type == WStype_CONNECTED) {
    Serial.print("Client connected: ");
    Serial.println(clientNum);
    webSocket.sendTXT(clientNum, "Connected to ESP32 chat");
  }

  if (type == WStype_TEXT) {
    String message = String((char*)payload);
    Serial.println(message);
    webSocket.broadcastTXT(message);
  }
}

void setup() {
  Serial.begin(115200);
  delay(1000);

  WiFi.softAP(ssid, password);

  Serial.println("ESP32 Chat started");
  Serial.println(WiFi.softAPIP());

  server.on("/", handleRoot);
  server.begin();

  webSocket.begin();
  webSocket.onEvent(webSocketEvent);
}

void loop() {
  server.handleClient();
  webSocket.loop();
}
